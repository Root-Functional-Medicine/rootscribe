{
  "name": "rootscribe",
  "version": "0.1.0",
  "private": true,
  "description": "Self-hosted server that mirrors Plaud recordings to local disk and triggers webhooks on new uploads.",
  "type": "module",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "concurrently -n web,srv -c cyan,magenta \"pnpm -C web dev\" \"pnpm -C server dev\"",
    "build": "pnpm -C shared build && pnpm -C web build && pnpm -C server build",
    "start": "pnpm build && node server/dist/index.js",
    "start:nobuild": "node server/dist/index.js",
    "start:mcp": "pnpm -F @rootscribe/inbox-mcp build 1>&2 && node inbox-mcp/dist/index.js",
    "typecheck": "pnpm -C shared build 1>&2 && pnpm -r typecheck",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:report": "playwright show-report",
    "ci": "pnpm lint && pnpm typecheck && pnpm test:coverage && pnpm test:e2e",
    "clean": "pnpm -r clean && rm -rf node_modules coverage playwright-report test-results"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "@vitest/coverage-v8": "^4.1.4",
    "@vitest/eslint-plugin": "^1.6.16",
    "concurrently": "^9.0.0",
    "eslint": "^10.2.1",
    "eslint-plugin-testing-library": "^7.16.2",
    "globals": "^17.5.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.58.2",
    "vitest": "^4.1.4"
  }
}
