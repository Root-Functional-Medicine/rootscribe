#!/usr/bin/env bash
#
# Pre-push guard — blocks pushes to the public upstream (rsteckler/applaud)
# so a stray `git push upstream ...` can't leak internal work to the fork
# source. RootScribe's canonical home is Root-Functional-Medicine/rootscribe
# — push only there.
#
# See CLAUDE.md ("Critical PR rule") for the background incident.
#
# Override with `git push --no-verify` only if you genuinely mean to push
# to upstream (in which case, prefer doing it from the rsteckler/applaud
# clone, not this one).

set -euo pipefail

remote_name="${1:-}"
remote_url="${2:-}"

# If the hook is invoked without a remote name (shouldn't happen via git),
# fall through without blocking so we don't break exotic workflows.
if [[ -z "${remote_name}" && -z "${remote_url}" ]]; then
  exit 0
fi

case "${remote_url}" in
  *rsteckler/applaud*|*rsteckler/rootscribe*)
    printf '\033[1;31m✗ BLOCKED:\033[0m push target %s resolves to rsteckler/applaud.\n' "${remote_name}" >&2
    printf '\n  RootScribe is a fork — %s must never receive internal changes.\n' "rsteckler/applaud" >&2
    printf '  Push to \033[1morigin\033[0m (Root-Functional-Medicine/rootscribe) instead:\n\n' >&2
    printf '    git push origin HEAD\n\n' >&2
    printf '  If you genuinely need to push to upstream, do it from an rsteckler/applaud\n' >&2
    printf '  clone — or bypass this hook with \033[1m--no-verify\033[0m (you will own the consequences).\n' >&2
    exit 1
    ;;
esac

exit 0
