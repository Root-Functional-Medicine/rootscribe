{
  "name": "@rootscribe/shared",
  "version": "0.1.1",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./test-factories": {
      "types": "./dist/test-factories/index.d.ts",
      "default": "./dist/test-factories/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "fishery": "^2.4.0",
    "typescript": "^6.0.3"
  }
}
